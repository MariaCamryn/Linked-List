import java.util.*;
class node{
  int data;
  ArrayList<node> children;
  node(int val){
    data=val;
    children=new ArrayList<>();
  }
}

public class Main{
  public static void main(String args[]){
    Scanner sc=new Scanner(System.in);
    Queue<node> q=new LinkedList<>();

    int val=sc.nextInt();
    node root=new node(val);
    q.add(root);
    ArrayList<Integer> list=new ArrayList<>();

    while(!q.isEmpty()&&sc.hasNextInt()){
      node curr=q.poll();
      list.add(curr.data);
      int c=sc.nextInt();

      for(int i=0;i<c;i++){
        int childval=sc.nextInt();
        node child=new node(childval);
        curr.children.add(child);
        q.add(child);
      }
    }
    for(int i:list){
      System.out.print(i+" ");
    }
  }
}
